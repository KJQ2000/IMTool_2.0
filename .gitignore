# IMTool Improved .gitignore

# Sensitive local configuration
/.streamlit/secrets.toml
/.streamlit/*.local.toml

# Python bytecode and build output
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Virtual environments and local env files
.env
.env.*
.venv/
venv/
env/
ENV/

# Test, coverage, and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Runtime output
/logs/
/staging/
/system_files/Import/
/system_files/Log/
*.log

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store

# Local scratch files
*.tmp
*.temp
*.bak
*.orig

# Knowledge Base
knowledge/

# docs
docs/